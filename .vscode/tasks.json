{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "SLATE: Install Dependencies",
      "type": "shell",
      "command": "npm",
      "args": ["install"],
      "options": {
        "cwd": "${workspaceFolder}/slate"
      },
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "SLATE: Run Dev Server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/slate"
      },
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "SLATE: Build",
      "type": "shell",
      "command": "npm",
      "args": ["run", "build"],
      "options": {
        "cwd": "${workspaceFolder}/slate"
      },
      "group": "build",
      "problemMatcher": []
    }
  ]
}
